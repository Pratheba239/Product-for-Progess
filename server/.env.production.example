# PP (Progress Over Perfection) Production Environment Variables

# Server
PORT=5000
NODE_ENV=production

# Database (Azure Database for PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/dbname?ssl=true
# OR individual variables
DB_HOST=pp-db.postgres.database.azure.com
DB_USER=ppadmin
DB_PASSWORD=your_password
DB_NAME=ppdb
DB_PORT=5432
DB_SSL=true

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-endpoint/

# Azure AD B2C (Authentication)
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_B2C_POLICY=B2C_1_SIGNUP_SIGNIN

# Azure Storage (Blob Storage)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=ppstorage;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=task-attachments

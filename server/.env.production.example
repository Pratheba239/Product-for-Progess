# --- PP_OS PRODUCTION ENVIRONMENT (AZURE) ---

# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://<your-static-web-app-name>.azurestaticapps.net

# Azure SQL Database (FREE TIER)
DB_HOST=<sql-server-name>.database.windows.net
DB_USER=dbadmin
DB_PASSWORD=<your-strong-password>
DB_NAME=ppdb
DB_SSL=true

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=<your-connection-string>
AZURE_STORAGE_CONTAINER_NAME=documents

# Azure Application Insights (Monitoring)
APPLICATIONINSIGHTS_CONNECTION_STRING=<your-connection-string>

# Azure AD / Entra ID (Auth)
AZURE_AD_CLIENT_ID=<backend-app-id>
AZURE_AD_TENANT_ID=<your-tenant-id>
AZURE_AD_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
AZURE_AD_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys

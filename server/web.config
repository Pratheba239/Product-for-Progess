<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config for Azure App Service (Windows)
  Routes all HTTP requests through the Node.js process managed by iisnode.
  Without this file, IIS returns its default page instead of your Express app.
-->
<configuration>
  <system.webServer>
    <handlers>
      <!-- Tells IIS to pass all requests to iisnode, which runs Node.js -->
      <add name="iisnode" path="index.js" verb="*" modules="iisnode"/>
    </handlers>
    <rewrite>
      <rules>
        <!-- Do not interfere with node_modules or static files -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="([\S]+[.](js|json|css|png|jpg|gif|ico|svg|woff|woff2|ttf|eot))" />
          <action type="None" />
        </rule>
        <!-- Route all other requests to the Node.js entry point -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True"/>
          </conditions>
          <action type="Rewrite" url="index.js"/>
        </rule>
      </rules>
    </rewrite>
    <!-- Allow iisnode to log errors for debugging -->
    <iisnode
      nodeProcessCommandLine="node"
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules"/>
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
